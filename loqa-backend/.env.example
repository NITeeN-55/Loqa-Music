# ⚠️  NEVER commit the real .env file to git!
# Copy this file to .env and fill in your values.

PORT=3000
NODE_ENV=development

# MongoDB Atlas connection string
MONGODB_URI=mongodb+srv://niteenwadhai55_db_user:NITeeN8975@loqa-music.fqfyj88.mongodb.net/loqa_music?retryWrites=true&w=majority&appName=Loqa-Music
# JWT secret — generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=<generate-a-64-byte-hex-secret>
JWT_EXPIRES_IN=7d

# Comma-separated list of allowed CORS origins
ALLOWED_ORIGINS=https://your-app.vercel.app,http://localhost:5173

# YouTube InnerTube API key (optional — see README for how to obtain)
# WARNING: Hardcoding this key violates YouTube ToS. Use at your own risk.
INNERTUBE_API_KEY=<your-innertube-api-key>

# Last.fm API key (optional — enables "similar artists" discovery in recommendations)
# Get one free at: https://www.last.fm/api/account/create
LASTFM_API_KEY=<your-lastfm-api-key>

# Rate limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=150

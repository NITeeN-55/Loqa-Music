# ── Server ────────────────────────────────────────────────────
PORT=3000
NODE_ENV=production

# ── MongoDB (Atlas) ───────────────────────────────────────────
# Get your URI from MongoDB Atlas → Connect → Drivers
# Format: mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority
MONGODB_URI=mongodb+srv://niteenwadhai55_db_user:NITeeN8975@loqa-music.fqfyj88.mongodb.net/loqa_music?retryWrites=true&w=majority&appName=Loqa-Music

# ── JWT ───────────────────────────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_64_byte_hex_secret_here
JWT_EXPIRES_IN=7d

# ── CORS ──────────────────────────────────────────────────────
# Set to your Vercel frontend URL (no trailing slash)
ALLOWED_ORIGINS=https://your-app.vercel.app

# ── YouTube InnerTube ─────────────────────────────────────────
# IMPORTANT: Never hardcode this key in source code. Keep it here only.
INNERTUBE_API_KEY=your_innertube_api_key_here

# ── Last.fm (optional — boosts recommendation discovery) ──────
# Free API key at: https://www.last.fm/api/account/create
# When set, recommendations include "similar artists" the user hasn't heard.
LASTFM_API_KEY=

# ── Rate limiting ─────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=150
